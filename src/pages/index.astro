---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import SocialLinks from '../components/SocialLinks.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events', ({ data }) => !data.draft);
const sortedEvents = allEvents.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const upcomingEvents = sortedEvents.filter(e => e.data.date >= new Date());
const pastEvents = sortedEvents.filter(e => e.data.date < new Date()).slice(0, 6);
---
<Layout title="Accueil" description="L'éducation financière et numérique pour tous.">

  <!-- Hero -->
  <PageHero
    title="Vous accompagner"
    description="L'éducation financière et numérique pour tous."
    image="/images/pages/home.webp"
    imageAlt="Bitcoin Alsace"
  >
    <p class="hero-meetup">
      🤝 Rejoignez-nous chaque <strong>2e mercredi du mois</strong> — <a href="/evenements">gratuit, sans inscription</a>.
    </p>
  </PageHero>

  <!-- Events section -->
  <section class="events-section">
    <div class="container">

      {upcomingEvents.length > 0 && (
        <div class="events-block">
          <h2 class="section-title">🔮 Évènements <span>à venir</span></h2>
          <div class="events-grid">
            {upcomingEvents.map(event => (
              <EventCard
                title={event.data.title}
                date={event.data.date}
                endDate={event.data.endDate}
                category={event.data.category}
                image={event.data.image}
                slug={event.id}
              />
            ))}
          </div>
        </div>
      )}

      {pastEvents.length > 0 && (
        <div class="events-block">
          <h2 class="section-title">Publications <span>récentes</span></h2>
          <div class="events-grid">
            {pastEvents.map(event => (
              <EventCard
                title={event.data.title}
                date={event.data.date}
                endDate={event.data.endDate}
                category={event.data.category}
                image={event.data.image}
                slug={event.id}
              />
            ))}
          </div>
          <div style="text-align:center; margin-top:2rem;">
            <a href="/evenements" class="btn btn-outline">Tous les évènements →</a>
          </div>
        </div>
      )}

    </div>
  </section>

  <!-- Contact strip -->
  <section class="contact-strip">
    <div class="container">
      <h2 class="section-title">Nous <span>suivre</span></h2>
      <SocialLinks />
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero-sub {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.95);
    margin-bottom: 1rem;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.55);
  }
  .hero-meetup {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 1.5rem;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.55);
  }
  .hero-meetup a {
    color: #fff;
    text-decoration: underline;
  }
  .hero-meetup a:hover {
    color: var(--orange-light);
  }

  /* Events */
  .events-section { padding: 3.5rem 0; }
  .events-block { margin-bottom: 3rem; }
  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  /* Contact */
  .contact-strip {
    padding: 2.5rem 0;
    background: linear-gradient(135deg, var(--orange-light) 0%, var(--white) 60%);
    border-top: 1px solid var(--border);
  }
</style>

<style is:global>
  /* Remove the footer's top margin specifically on the home page to remove the gap after the contact strip */
  .site-footer {
    margin-top: 0 !important;
  }
</style>
