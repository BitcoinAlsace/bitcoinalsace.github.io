---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const events = await getCollection('events', ({ data }) => !data.draft);
  return events.map(event => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const categoryLabels = {
  meetup: '🤝 Bitcoin Meetup',
  conference: '🗣️ Conférence',
  actu: '🎭 Actualité',
  autre: '📅 Événement',
};

const formatDate = (d: Date) =>
  d.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });

// Date-only YAML values are parsed as UTC midnight → getUTCHours/Minutes both 0
const hasTime = (d: Date) => d.getUTCHours() !== 0 || d.getUTCMinutes() !== 0;

const formatTime = (d: Date) =>
  d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });

const isUpcoming = event.data.date >= new Date();
---
<Layout
  title={event.data.title}
  description={event.data.description ?? `${event.data.title} — Bitcoin Alsace`}
  ogImage={event.data.image}
>
  <div class="event-page-header">
    <div class="container">
      <a href="/evenements" class="back-link">← Tous les événements</a>
      <div class="event-meta-top">
        <span class={`badge badge-${event.data.category}`}>{categoryLabels[event.data.category]}</span>
        {isUpcoming && <span class="badge-upcoming">À venir</span>}
      </div>
      <h1>{event.data.title}</h1>
      <div class="event-info">
        <time datetime={event.data.date.toISOString()}>
          📅 {formatDate(event.data.date)}{hasTime(event.data.date) ? ` à ${formatTime(event.data.date)}` : ''}{event.data.endDate ? ` – ${formatDate(event.data.endDate)}${hasTime(event.data.endDate) ? ` à ${formatTime(event.data.endDate)}` : ''}` : ''}
        </time>
        {event.data.location && <span>📍 {event.data.location}</span>}
        {event.data.free && <span class="free-badge">Gratuit</span>}
        {!event.data.free && event.data.price !== undefined && <span>💰 {event.data.price}€</span>}
      </div>
    </div>
  </div>

  <div class="page-content">
    <div class="container">

      <article class="prose event-content">
        {event.data.image && (
          <img src={event.data.image} alt={event.data.title} class="event-cover" />
        )}
        <Content />

        {event.data.registrationUrl && (
          <div class="register-cta">
            <a href={event.data.registrationUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              S'inscrire / Rejoindre
            </a>
          </div>
        )}
      </article>

    </div>
  </div>
</Layout>

<style>
  .event-page-header {
    background: linear-gradient(135deg, var(--orange-light), var(--white));
    border-bottom: 1px solid var(--border);
    padding: 2.5rem 0 2rem;
  }
  .event-page-header h1 { margin-bottom: 0.75rem; }
  .back-link {
    display: inline-block;
    font-size: 0.9rem;
    color: var(--gray);
    margin-bottom: 1rem;
    text-decoration: none;
  }
  .back-link:hover { color: var(--orange); }

  .event-meta-top {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .badge-upcoming {
    background: #dcfce7;
    color: #166534;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .event-info {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.95rem;
    color: var(--gray);
  }
  .free-badge {
    background: var(--orange-light);
    color: var(--orange-dark);
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.85rem;
  }

  .event-content { max-width: 720px; }

  .event-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius, 8px);
    margin-bottom: 2rem;
    display: block;
  }

  .event-content { line-height: 1.75; }
  .register-cta { margin-top: 2rem; }
</style>
