---
import Layout from "../layouts/Layout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import PageHero from "../components/PageHero.astro";
import BookCard from "../components/BookCard.astro";
---

<Layout
  title="Bibliothèque"
  description="Ressources recommandées par Bitcoin Alsace : livres, podcasts, documents sur Bitcoin et les cryptomonnaies. Accès gratuit en Alsace."
  ogImage="/images/pages/Bitcoin_Alsace_Bibliotheque-2.webp"
>
  <PageHero
    title="Bibliothèque"
    description="Découvrez gratuitement !"
    image="/images/pages/Bitcoin_Alsace_Bibliotheque-2.webp"
    imageAlt="Bibliothèque Bitcoin Alsace"
  />

  <div class="page-content">
    <div class="container content-layout">
      <article class="prose main-content">
        <p class="intro-lead">L'éducation, de 7 à 77 ans</p>
        <p>
          Blockchain, décentralisation, Bitcoin, cryptomonnaies… Plongez dans le
          terrier du savoir !
        </p>
        <p>
          Quelques recommandations — livres, podcasts et DVDs à emprunter
          gratuitement, pour tous les âges et tous les niveaux.
        </p>

        <h2>Bibliothèques publiques en Alsace</h2>

        <div class="library-grid">
          <div class="library-region">
            <h3 class="region-label">Bas-Rhin</h3>
            <a href="https://biblio.bnu.fr/opac/query/bitcoin?context=catalogo" class="library-card" target="_blank" rel="noopener noreferrer">
              <div class="library-card-body">
                <span class="library-icon">📚</span>
                <span class="library-name">BNU de Strasbourg</span>
              </div>
              <span class="library-cta">Consulter le catalogue →</span>
            </a>
            <a href="https://www.mediatheques.strasbourg.eu/search.aspx?SC=PUBLIC&QUERY=bitcoin&QUERY_LABEL=#/Search/(query:(InitialSearch:!t,Page:0,PageRange:3,QueryString:bitcoin,ResultSize:-1,ScenarioCode:PUBLIC,SearchContext:0,SearchLabel:''))" class="library-card" target="_blank" rel="noopener noreferrer">
              <div class="library-card-body">
                <span class="library-icon">📚</span>
                <span class="library-name">Médiathèques Eurométropole</span>
              </div>
              <span class="library-cta">Consulter le catalogue →</span>
            </a>
          </div>

          <div class="library-region">
            <h3 class="region-label">Haut-Rhin</h3>
            <a href="https://bibliotheques.mulhouse.fr/recherche/simple/expressionRecherche/bitcoin/tri/%2A" class="library-card" target="_blank" rel="noopener noreferrer">
              <div class="library-card-body">
                <span class="library-icon">📚</span>
                <span class="library-name">Bibliothèques de Mulhouse</span>
              </div>
              <span class="library-cta">Consulter le catalogue →</span>
            </a>
            <a href="https://www.learning-center.uha.fr/opac/query/bitcoin?context=catalogo" class="library-card" target="_blank" rel="noopener noreferrer">
              <div class="library-card-body">
                <span class="library-icon">📚</span>
                <span class="library-name">UHA — Learning Center</span>
              </div>
              <span class="library-cta">Consulter le catalogue →</span>
            </a>
          </div>
        </div>

        <h2>Quelques recommandations</h2>
        <h3>Pour les débutants</h3>
        <div class="book-covers-grid">
          <BookCard title="« L'élégance de Bitcoin »" author="Ludovic Lars" image="/images/books/elegance-de-bitcoin.webp" note="Lecture gratuite en ligne disponible" highlight link="https://bitcoinelegance.fr/" linkLabel="Lire gratuitement" />
          <BookCard title="« L'étalon-bitcoin »" author="Saifedean Ammous" image="/images/books/the-bitcoin-standard.webp" note="Traduit par Marie Oneissi" highlight />
          <BookCard title="« Alice au pays des cryptos »" author="Daniel Villa Monteiro & Nicolas Balas" image="/images/books/alice-au-pays-des-cryptos.jpg" />
          <BookCard title="« Cryptomonnaies facile »" author="Claire Balva & Alexandre Stachtchenko" image="/images/books/bitcoin-cryptomonnaies-faciles.webp" />
          <BookCard title="« Le petit livre des cryptomonnaies »" author="Stanislas Barthélémi" image="/images/books/le-petit-livre-des-cryptomonnaies.webp" />
        </div>

        <h3>Pour les plus curieux</h3>
        <div class="book-covers-grid">
          <BookCard title="« La guerre des blocs »" author="Jonathan Bier" image="/images/books/the-blocksize-war.webp" />
          <BookCard title="« J'ai vendu mon âme en bitcoins »" author="Jake Adelstein" image="/images/books/jai-vendu-mon-ame-en-bitcoins.webp" />
          <BookCard title="« Bitcoinica »" author="Ali Mitchell" image="/images/books/bitcoinica.jpg" />
          <BookCard title="Livre Blanc Bitcoin" author="Satoshi Nakamoto" image="/images/books/bitcoin-whitepaper.webp" link="/bitcoin_fr.pdf" />
          <BookCard title="Manifeste d'un Cypherpunk" author="Eric Hughes, 1993" image="/images/books/manifeste-cypherpunk.jpg" link="/cypherpunks-manifesto-fr.pdf" />
        </div>

        <div class="planb-section">
          <h2>Plan ₿ Academy</h2>
          <p>
            La <a
              href="https://planb.academy/fr/"
              target="_blank"
              rel="noopener noreferrer">Plan ₿ Academy</a
            >
            propose des formations en ligne gratuites et de qualité sur Bitcoin, du
            niveau débutant à expert.
          </p>
        </div>
      </article>

      <aside class="sidebar">
        <div class="card sidebar-card">
          <h3>Nous contacter</h3>
          <p style="font-size:0.9rem;color:var(--gray);margin-bottom:1rem;">
            Une question sur notre bibliothèque ou envie de proposer une
            ressource ?
          </p>
          <SocialLinks hideRss={true} />
        </div>

        <div class="card sidebar-card">
          <h3>Ressources à télécharger</h3>
          <ul class="download-list">
            <li>
              <a href="/bitcoin_fr.pdf" target="_blank">
                📄 Livre Blanc Bitcoin
              </a>
            </li>
            <li>
              <a href="/cypherpunks-manifesto-fr.pdf" target="_blank">
                📄 Manifeste d'un Cypherpunk
              </a>
            </li>
          </ul>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  .library-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 1rem 0 2rem;
  }
  @media (max-width: 600px) {
    .library-grid { grid-template-columns: 1fr; }
  }
  .library-region { display: flex; flex-direction: column; gap: 0.75rem; }
  .region-label {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gray);
    margin: 0 0 0.25rem;
  }
  .library-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--white);
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }
  .library-card:hover {
    border-color: var(--orange);
    box-shadow: 0 2px 12px rgba(247,147,26,0.12);
    transform: translateY(-1px);
  }
  .library-card-body {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .library-icon { font-size: 1.1rem; flex-shrink: 0; }
  .library-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--black);
  }
  .library-cta {
    font-size: 0.78rem;
    color: var(--orange);
    font-weight: 600;
  }
  [data-theme="dark"] .library-card {
    background: var(--card-bg, #1a1a1a);
  }

  .intro-lead {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--black);
    margin-bottom: 0.25rem;
  }

  .content-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .content-layout {
      grid-template-columns: 1fr;
    }
  }

  .sidebar-card {
    margin-bottom: 1.5rem;
  }
  .sidebar-card h3 {
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--orange);
    display: inline-block;
  }

  .book-covers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(195px, 1fr));
    gap: 1rem;
    margin: 1rem 0 2rem;
  }
  .planb-section {
    border: 2px solid var(--orange);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin: 2rem 0;
    background: var(--orange-light);
  }
  .planb-section h2 {
    margin-top: 0;
  }
  [data-theme="dark"] .planb-section {
    background: rgba(247, 147, 26, 0.08);
  }

  .doc-link {
    margin-left: 0.5rem;
    font-size: 0.82rem;
    background: var(--orange-light);
    color: var(--orange-dark);
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
  }

  .download-list {
    list-style: none;
    padding: 0;
  }
  .download-list li {
    margin-bottom: 0.5rem;
  }
  .download-list a {
    font-size: 0.9rem;
  }
</style>
