---
interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
}

const { title, description, image, imageAlt = '' } = Astro.props;
---

<div class={`page-hero${image ? ' page-hero--banner' : ''}`}>
  {image && <img class="page-hero-img" src={image} alt={imageAlt} />}
  {image && <div class="page-hero-overlay" aria-hidden="true" />}
  <div class="container page-hero-content">
    <slot name="before-title" />
    <h1>{title}</h1>
    {description && <p>{description}</p>}
    <slot />
  </div>
</div>

<style>
  /* ── Base (no image) ── */
  .page-hero {
    position: relative;
    background: linear-gradient(135deg, var(--orange-light), var(--white));
    border-bottom: 1px solid var(--border);
    padding: 4.5rem 0;
    overflow: hidden;
    --page-hero-muted-color: var(--gray);
  }
  .page-hero h1 { margin-bottom: 0.5rem; }
  .page-hero p {
    color: var(--gray);
    font-size: 1.05rem;
  }

  /* ── Banner mode (image provided) ── */
  .page-hero--banner {
    background: none;
    border-bottom: none;
    height: calc(100dvh - var(--header-height));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    --page-hero-muted-color: rgba(255, 255, 255, 0.82);
  }

  .page-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
  }

  .page-hero-content {
    position: relative;
    z-index: 1;
  }

  .page-hero--banner .page-hero-content {
    width: 100%;
    text-align: center;
    padding: 2rem;
  }

  .page-hero--banner h1 {
    color: #fff;
    font-size: clamp(2rem, 5vw, 3.5rem);
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.6);
    margin-bottom: 1rem;
  }

  .page-hero--banner p {
    color: var(--page-hero-muted-color);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.55);
    font-size: clamp(1rem, 2vw, 1.25rem);
    max-width: 60ch;
    margin: 0 auto;
  }
</style>
